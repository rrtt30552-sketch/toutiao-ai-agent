# ============================================================
# AI API 配置
# 复制此文件为 .env，填入 API Key，取消注释你想用的那组配置
# ============================================================

# ── MiMo ──
# AI_API_KEY=your-key-here
# AI_API_BASE_URL=https://api.xiaomimimo.com/v1
# AI_MODEL=mimo-v2.5

# ── DeepSeek ──
# AI_API_KEY=your-key-here
# AI_API_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# ── OpenAI ──
# AI_API_KEY=your-key-here
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ── 通义千问 ──
# AI_API_KEY=your-key-here
# AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-turbo

# ── Kimi ──
# AI_API_KEY=your-key-here
# AI_API_BASE_URL=https://api.moonshot.cn/v1
# AI_MODEL=moonshot-v1-8k

# ── 智谱GLM ──
# AI_API_KEY=your-key-here
# AI_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4-flash
